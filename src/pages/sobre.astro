---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Link from '../components/ui/Link.astro';

const fernando = await getEntry('authors', 'fernando');
const data = fernando!.data;
const { Content } = await render(fernando!);
---

<BaseLayout
  title="Sobre"
  description="Fernando Adão, fundador da FoxAlpha. Modelo enxuto de operação, time montado por projeto."
>
  <Container size="default">
    <div class="py-16 md:py-24">
      <p class="text-sm text-[var(--ink-mute)] uppercase tracking-wide mb-4">Sobre</p>
      <h1 class="font-[var(--font-display)] text-5xl md:text-7xl mb-12 max-w-3xl leading-[1.05]">
        Estúdio enxuto.<br />
        <em class="italic font-light text-[var(--accent)]">Sênior do início ao fim.</em>
      </h1>
    </div>
  </Container>

  <Container size="default">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 pb-24">
      <div class="md:col-span-5">
        <div class="aspect-square bg-[var(--bg-elev)] rounded-lg overflow-hidden border border-[var(--rule)] sticky top-24">
          {data.photo ? (
            <img src={data.photo} alt={data.name} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-[var(--ink-mute)] text-sm">
              Foto em breve
            </div>
          )}
        </div>
      </div>

      <div class="md:col-span-7">
        <p class="text-sm text-[var(--ink-mute)] uppercase tracking-wide mb-2">{data.role}</p>
        <h2 class="font-[var(--font-display)] text-4xl mb-8">{data.name}</h2>
        <p class="text-xl text-[var(--ink-soft)] leading-relaxed mb-8">{data.bio}</p>

        <div class="flex flex-wrap gap-6 mb-12 text-sm">
          {data.linkedin && <Link href={data.linkedin} external>LinkedIn</Link>}
          {data.github && <Link href={data.github} external>GitHub</Link>}
          {data.email && <Link href={`mailto:${data.email}`}>Email</Link>}
        </div>

        <div class="prose prose-lg">
          <Content />
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>
