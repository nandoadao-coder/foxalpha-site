---
const clients = [
  { name: 'Numem', url: 'https://numem.com.br' },
  { name: 'NumemBot', url: 'https://chat2.numem.com.br' },
  { name: 'Azul Empréstimos', url: 'https://azul.numem.com.br' },
  { name: 'RD Saúde Dental', url: 'https://rdsaudedental.com.br' },
  { name: 'Doe Seu Cupom', url: 'https://doeseucupom.com.br' },
];
---

<section class="py-12 border-y border-[var(--rule)]">
  <div class="max-w-[1280px] mx-auto px-6 md:px-16">
    <p class="text-sm text-[var(--ink-mute)] mb-6 text-center">
      Trabalhos em produção, escolhidos pelo cliente:
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
      {clients.map(client => (
        <a
          href={client.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--ink-mute)] hover:text-[var(--ink)] transition-colors text-lg font-[var(--font-display)]"
        >
          {client.name}
        </a>
      ))}
    </div>
  </div>
</section>
