---
import { getEntry } from 'astro:content';
import Container from '../ui/Container.astro';
import Link from '../ui/Link.astro';

const fernando = await getEntry('authors', 'fernando');
const data = fernando!.data;
---

<section class="py-24">
  <Container size="default">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-5">
        <div class="aspect-square bg-[var(--bg-elev)] rounded-lg overflow-hidden border border-[var(--rule)]">
          {data.photo ? (
            <img src={data.photo} alt={data.name} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-[var(--ink-mute)] text-sm">
              Foto em breve
            </div>
          )}
        </div>
      </div>

      <div class="md:col-span-7">
        <p class="text-sm text-[var(--ink-mute)] uppercase tracking-wide mb-4">{data.role}</p>
        <h2 class="font-[var(--font-display)] text-4xl md:text-5xl mb-8">
          {data.name}
        </h2>
        <p class="text-lg text-[var(--ink-soft)] leading-relaxed mb-8 whitespace-pre-line">
          {data.bio}
        </p>

        <div class="flex flex-wrap gap-6 text-sm">
          {data.linkedin && <Link href={data.linkedin} external>LinkedIn</Link>}
          {data.github && <Link href={data.github} external>GitHub</Link>}
          {data.email && <Link href={`mailto:${data.email}`}>Email</Link>}
        </div>
      </div>
    </div>
  </Container>
</section>
