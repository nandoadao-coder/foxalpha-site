---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

const navItems = [
  { href: '/trabalhos', label: 'Trabalhos' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/escrita', label: 'Escrita' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[color-mix(in_srgb,var(--bg)_80%,transparent)] border-b border-[var(--rule)]"
>
  <Container size="default">
    <nav class="flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-3" aria-label="FoxAlpha — Home">
        <img src="/favicon.svg" alt="" width="32" height="32" />
        <span class="font-[var(--font-display)] text-xl tracking-tight">FoxAlpha</span>
      </a>

      <div class="flex items-center gap-8">
        <ul class="hidden md:flex gap-8">
          {navItems.map(item => (
            <li>
              <a
                href={item.href}
                class={`text-sm transition-colors ${
                  currentPath.startsWith(item.href)
                    ? 'text-[var(--ink)]'
                    : 'text-[var(--ink-soft)] hover:text-[var(--ink)]'
                }`}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <Button href="/diagnostico" variant="primary" size="sm">
          Diagnóstico →
        </Button>
      </div>
    </nav>
  </Container>
</header>
