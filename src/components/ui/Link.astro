---
interface Props {
  href: string;
  external?: boolean;
  class?: string;
}

const { href, external = false, class: className = '' } = Astro.props;
const targetProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  {...targetProps}
  class={`group relative inline-block text-[var(--accent)] hover:text-[#A24F22] transition-colors ${className}`}
>
  <span><slot /></span>
  <span
    class="absolute bottom-0 left-0 h-px w-full origin-left scale-x-0 bg-current transition-transform duration-200 group-hover:scale-x-100"
  ></span>
</a>
