---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
}

const {
  title = 'FoxAlpha — Inteligência artificial em produção, sem teatro',
  description = 'Consultoria boutique de IA. Implementamos sistemas que resolvem problemas reais de empresas que já levaram a sério a transformação digital.',
  ogImage = '/og-default.png',
  type = 'website',
} = Astro.props;

const fullTitle = title.includes('FoxAlpha') ? title : `${title} — FoxAlpha`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'FoxAlpha',
  url: 'https://foxalpha.com.br',
  logo: 'https://foxalpha.com.br/favicon.svg',
  description,
  sameAs: [
    'https://github.com/nandoadao-coder',
    'https://www.linkedin.com/in/fernandoadao/',
  ],
};
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content="pt_BR" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<script is:inline type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
